{
    "name": "rjv-technologies/agi-bridge",
    "description": "Enterprise AGI control interface for WordPress with dual AI support (OpenAI + Anthropic)",
    "type": "wordpress-plugin",
    "license": "proprietary",
    "authors": [
        {
            "name": "RJV Technologies Ltd",
            "homepage": "https://rjvtechnologies.com"
        }
    ],
    "require": {
        "php": ">=8.1",
        "ext-json": "*",
        "ext-mbstring": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "phpstan/phpstan": "^1.12",
        "wp-coding-standards/wpcs": "^3.1",
        "phpcompatibility/phpcompatibility-wp": "*",
        "squizlabs/php_codesniffer": "^3.9"
    },
    "autoload": {
        "psr-4": {
            "RJV_AGI_Bridge\\": "includes/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "RJV_AGI_Bridge\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "lint": [
            "phpcs --standard=WordPress --extensions=php --ignore=vendor,node_modules includes/",
            "phpstan analyse includes/ --level=6 --no-progress"
        ],
        "test": "phpunit --testdox"
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    },
    "minimum-stability": "stable"
}
